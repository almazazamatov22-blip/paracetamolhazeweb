    "html": "<html lang=\"ru\"><head><script src=\"https://mc.yandex.com/metrika-tags/_/tag_ec.js\" type=\"text/javascript\" charset=\"utf-8\" async=\"\"></script>\n    <meta charset=\"UTF-8\">\n    <!-- Yandex.Metrika counter -->\n<script async=\"\" src=\"https://mc.yandex.ru/metrika/tag.js?id=105293610\"></script><script type=\"text/javascript\">\n    (function(m,e,t,r,i,k,a){\n        m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};\n        m[i].l=1*new Date();\n        for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}\n        k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)\n    })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=105293610', 'ym');\n\n    ym(105293610, 'init', {ssr:true, clickmap:true, ecommerce:\"dataLayer\", accurateTrackBounce:true, trackLinks:true});\n</script>\n<noscript><div><img src=\"https://mc.yandex.ru/watch/105293610\" style=\"position:absolute; left:-9999px;\" alt=\"\" /></div></noscript>\n<!-- /Yandex.Metrika counter -->\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>VelRoll - Twitch Чат Рулетка</title>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <link rel=\"stylesheet\" href=\"css/style3.css\">\n</head>\n<body>\n    <div class=\"app-container\">\n        <header class=\"app-header\">\n            <div class=\"header-gradient\">\n                <div class=\"header-content\">\n                    <div class=\"logo\">\n                        <div class=\"logo-icon\">\n                            <i class=\"fas fa-dice\"></i>\n                        </div>\n                        <div class=\"logo-text\">\n                            <h1>VelRoll</h1>\n                            <p class=\"tagline\">Twitch Чат Рулетка (Включайте аппаратное ускорение в браузере, чтобы не было лагов)</p>\n                        </div>\n                    </div>\n                    <a href=\"https://velgardi.ru/quiz/game\" target=\"_blank\" class=\"header-banner-link\">\n    <img src=\"tsq.png\" alt=\"Banner\" class=\"header-banner\">\n</a>\n<div class=\"version-badge\">\n    <span>v0.7</span>\n</div>\n                </div>\n            </div>\n        </header>\n\n        <main class=\"app-main\">\n            <section class=\"control-section\">\n                <div class=\"panel glass-panel\">\n                    <div class=\"panel-header\">\n                        <i class=\"fas fa-sliders-h\"></i>\n                        <h2>Управление розыгрышем</h2>\n                    </div>\n                    \n                    <div class=\"form-group\">\n                        <label for=\"streamerName\">\n                            <i class=\"fas fa-user\"></i>\n                            Никнейм стримера\n                        </label>\n                        <div class=\"input-with-icon\">\n                            <i class=\"fas fa-at\"></i>\n                            <input type=\"text\" id=\"streamerName\" placeholder=\"Введите никнейм стримера\" value=\"veigardi\">\n                        </div>\n                    </div>\n                    \n                    <div class=\"form-group\">\n                        <label for=\"keyword\">\n                            <i class=\"fas fa-key\"></i>\n                            Ключевое слово для участия\n                        </label>\n                        <div class=\"input-with-icon\">\n                            <i class=\"fas fa-hashtag\"></i>\n                            <input type=\"text\" id=\"keyword\" placeholder=\"Введите ключевое слово\" value=\"розыгрыш\">\n                        </div>\n                    </div>\n\n                    <div class=\"button-group\">\n                        <button id=\"connectBtn\" class=\"btn-primary\">\n                            <i class=\"fas fa-plug\"></i>\n                            <span>Начать Отбор</span>\n                        </button>\n                        <button id=\"disconnectBtn\" class=\"btn-secondary\" style=\"display: none;\">\n                            <i class=\"fas fa-power-off\"></i>\n                            <span>Отключиться</span>\n                        </button>\n                    </div>\n                    <div id=\"status\" class=\"status-message disconnected\">\n                        <i class=\"fas fa-info-circle\"></i>\n                        <span>Введите никнейм стримера и ключевое слово, затем нажмите \"Начать Отбор\"</span>\n                    </div>\n\n                    <div class=\"stats-grid\">\n                        <div class=\"stat-card\">\n                            <div class=\"stat-icon\">\n                                <i class=\"fas fa-users\"></i>\n                            </div>\n                            <div class=\"stat-info\">\n                                <span class=\"stat-value\" id=\"participantsCount\">0</span>\n                                <span class=\"stat-label\">Участников</span>\n                            </div>\n                        </div>\n                        <div class=\"stat-card\">\n                            <div class=\"stat-icon\">\n                                <i class=\"fas fa-comments\"></i>\n                            </div>\n                            <div class=\"stat-info\">\n                                <span class=\"stat-value\" id=\"totalMessagesCount\">0</span>\n                                <span class=\"stat-label\">Сообщений</span>\n                            </div>\n                        </div>\n                        <div class=\"stat-card\">\n                            <div class=\"stat-icon\">\n                                <i class=\"fas fa-clock\"></i>\n                            </div>\n                            <div class=\"stat-info\">\n                                <span class=\"stat-value\" id=\"connectionTime\">0:00</span>\n                                <span class=\"stat-label\">Время работы</span>\n                            </div>\n                        </div>\n                    </div>\n\n                    <button id=\"startRouletteBtn\" class=\"btn-success\" disabled=\"\">\n                        <i class=\"fas fa-play\"></i>\n                        <span>Начать розыгрыш - Рулетка</span>\n                    </button>\n\n                    <button id=\"startVaseRouletteBtn\" class=\"btn-warning\" disabled=\"\">\n                        <i class=\"fas fa-gift\"></i>\n                        <span>Начать розыгрыш - Вазы</span>\n                    </button>\n\n                    <button id=\"startCsRouletteBtn\" class=\"btn-cs\" disabled=\"\">\n                        <i class=\"fas fa-crosshairs\"></i>\n                        <span>Начать розыгрыш - КС</span>\n                    </button>\n                    <button id=\"startCubeBattleBtnMain\" class=\"btn-cube\" disabled=\"\">\n    <span>Начать розыгрыш - Пиксель Рояль</span>\n</button>\n                </div>\n            </section>\n\n            <section class=\"chat-section\">\n                <div class=\"panel glass-panel\">\n                    <div class=\"panel-header winner-header\">\n                        <div class=\"winner-title\">\n    <i class=\"fas fa-crown\"></i>\n    <h2 id=\"winnerUsernameDisplay\">Чат победителя</h2>\n\n<span id=\"winnerWaitTime\" class=\"winner-wait-time\"></span></div>\n                        <div class=\"winner-badge\" id=\"winnerBadge\" style=\"display: none;\">\n                            <span></span>\n                        </div>\n                    </div>\n                    <div id=\"winnerMessages\" class=\"messages-container empty-state\">\n                        <i class=\"fas fa-comment-slash\"></i>\n                        <p>Сообщения победителя появятся здесь</p>\n                    </div>\n                </div>\n            </section>\n\n            <section class=\"participants-section\">\n                <div class=\"panel glass-panel\">\n                    <div class=\"panel-header\">\n                        <i class=\"fas fa-list\"></i>\n                        <h2>Участники розыгрыша</h2>\n                    </div>\n                    <div id=\"usersList\" class=\"participants-list empty-state\">\n                        <i class=\"fas fa-user-plus\"></i>\n                        <p>Участники появятся здесь после написания ключевого слова в чате</p>\n                    </div>\n                </div>\n            </section>\n        </main>\n\n        <footer class=\"app-footer\">\n            <div class=\"footer-content\">\n                <p>© 2025 VelRoll Twitch</p>\n            </div>\n        </footer>\n    </div>\n\n    <div class=\"roulette-modal\" id=\"rouletteSection\">\n        <div class=\"modal-overlay\"></div>\n        <div class=\"modal-content\">\n            <div class=\"roulette-container\">\n                <div class=\"roulette-header\">\n                    <h3>Розыгрыш начался!</h3>\n                    <p>Крутите рулетку для выбора победителя</p>\n                </div>\n                \n                <div class=\"roulette-wheel-container\">\n                    <div class=\"roulette-wheel\" id=\"rouletteWheel\"></div>\n                    <div class=\"roulette-pointer\">\n                        <i class=\"fas fa-arrow-down\"></i>\n                    </div>\n                </div>\n\n                <div class=\"roulette-controls\">\n                    <button id=\"spinRouletteBtn\" class=\"btn-primary\">\n                        <i class=\"fas fa-redo\"></i>\n                        <span>Крутить рулетку</span>\n                    </button>\n                    <button id=\"closeRouletteBtn\" class=\"btn-secondary\">\n                        <i class=\"fas fa-times\"></i>\n                        <span>Закрыть</span>\n                    </button>\n                </div>\n\n                <div class=\"roulette-winner\" id=\"rouletteWinner\">\n                    <div class=\"winner-celebration\">\n                        <div class=\"confetti\"></div>\n                        <div class=\"confetti\"></div>\n                        <div class=\"confetti\"></div>\n                    </div>\n                    <div class=\"winner-avatar\" id=\"winnerAvatar\">\n                        <i class=\"fas fa-crown\"></i>\n                    </div>\n                    <div class=\"winner-info\">\n                        <div class=\"winner-name\" id=\"winnerName\">Победитель</div>\n                        <div class=\"winner-text\">Поздравляем с победой в розыгрыше!</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <div class=\"vase-roulette-modal\" id=\"vaseRouletteSection\">\n        <div class=\"modal-overlay\"></div>\n        <div class=\"modal-content\">\n            <div class=\"vase-container\">\n                <div class=\"vase-header\">\n                    <h3>Розыгрыш вазами!</h3>\n                    <p>Кликайте на вазы, чтобы разбить их и найти победителя</p>\n                </div>\n                \n                <div class=\"vases-grid\" id=\"vasesGrid\">\n                </div>\n\n                <div class=\"vase-controls\">\n                    <button id=\"closeVaseRouletteBtn\" class=\"btn-secondary\">\n                        <i class=\"fas fa-times\"></i>\n                        <span>Закрыть</span>\n                    </button>\n                </div>\n\n                <div class=\"vase-winner-display\" id=\"vaseWinnerDisplay\">\n                    <div class=\"winner-celebration\">\n                        <div class=\"confetti\"></div>\n                        <div class=\"confetti\"></div>\n                        <div class=\"confetti\"></div>\n                    </div>\n                    <div class=\"vase-winner-avatar\" id=\"vaseWinnerAvatar\">\n                        <i class=\"fas fa-crown\"></i>\n                    </div>\n                    <div class=\"winner-info\">\n                        <div class=\"winner-name\" id=\"vaseWinnerName\">Победитель</div>\n                        <div class=\"winner-text\">Поздравляем с победой в розыгрыше!</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n\n<div class=\"cs-roulette-modal\" id=\"csRouletteSection\">\n    <div class=\"modal-overlay\"></div>\n    <div class=\"modal-content\">\n        <div class=\"cs-container\">\n            <div class=\"cs-header\">\n                <h3>Розыгрыш через Counter-Strike</h3>\n                <p>Из списка ниже выбираются 10 человек, из которых выиграет только 1</p>\n            </div>\n            \n            <div class=\"participants-grid\" id=\"csParticipantsGrid\">\n           \n            </div>\n\n            <div class=\"cs-content\">\n                <div class=\"team-column team-terrorist\">\n                    <div class=\"team-header\">TERRORISTS</div>\n                    <div class=\"player-with-marker\">\n                        <div class=\"player-marker\">6</div>\n                        <div class=\"team-player\" id=\"terroristPlayer1\"></div>\n                    </div>\n                    <div class=\"player-with-marker\">\n                        <div class=\"player-marker\">7</div>\n                        <div class=\"team-player\" id=\"terroristPlayer2\"></div>\n                    </div>\n                    <div class=\"player-with-marker\">\n                        <div class=\"player-marker\">8</div>\n                        <div class=\"team-player\" id=\"terroristPlayer3\"></div>\n                    </div>\n                    <div class=\"player-with-marker\">\n                        <div class=\"player-marker\">9</div>\n                        <div class=\"team-player\" id=\"terroristPlayer4\"></div>\n                    </div>\n                    <div class=\"player-with-marker\">\n                        <div class=\"player-marker\">0</div>\n                        <div class=\"team-player\" id=\"terroristPlayer5\"></div>\n                    </div>\n                </div>\n                \n                <div class=\"cs-video-container\">\n                    <video class=\"cs-video\" id=\"csVideo\" preload=\"metadata\">\n                        <source src=\"cs1.webm\" type=\"video/webm\">\n                        Ваш браузер не поддерживает webm тег.\n                    </video>\n                    \n                    \n                    <div class=\"cs-winner-display-overlay\" id=\"csWinnerDisplay\">\n                        <div class=\"winner-celebration\">\n                            <div class=\"confetti\"></div>\n                            <div class=\"confetti\"></div>\n                            <div class=\"confetti\"></div>\n                        </div>\n                        <div class=\"cs-winner-avatar-overlay\" id=\"csWinnerAvatar\">\n                            <i class=\"fas fa-crown\"></i>\n                        </div>\n                        <div class=\"winner-info-overlay\">\n                            <div class=\"winner-name-overlay\" id=\"csWinnerName\">Победитель</div>\n                            <div class=\"winner-text-overlay\">Поздравляем <span class=\"winner-username\"></span> с победой в розыгрыше!</div>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"team-column team-counter\">\n                    <div class=\"team-header\">COUNTER-TERRORISTS</div>\n                    <div class=\"player-with-marker\">\n                        <div class=\"player-marker\">1</div>\n                        <div class=\"team-player\" id=\"counterPlayer1\"></div>\n                    </div>\n                    <div class=\"player-with-marker\">\n                        <div class=\"player-marker\">2</div>\n                        <div class=\"team-player\" id=\"counterPlayer2\"></div>\n                    </div>\n                    <div class=\"player-with-marker\">\n                        <div class=\"player-marker\">3</div>\n                        <div class=\"team-player\" id=\"counterPlayer3\"></div>\n                    </div>\n                    <div class=\"player-with-marker\">\n                        <div class=\"player-marker\">4</div>\n                        <div class=\"team-player\" id=\"counterPlayer4\"></div>\n                    </div>\n                    <div class=\"player-with-marker\">\n                        <div class=\"player-marker\">5</div>\n                        <div class=\"team-player\" id=\"counterPlayer5\"></div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"cs-controls\">\n                <button id=\"startCsSelectionBtn\" class=\"btn-primary\">\n                    <i class=\"fas fa-play\"></i>\n                    <span>Начать отбор</span>\n                </button>\n                <button id=\"closeCsRouletteBtn\" class=\"btn-secondary\">\n                    <i class=\"fas fa-times\"></i>\n                    <span>Закрыть</span>\n                </button>\n            </div>\n        </div>\n    </div>\n</div>\n<div class=\"cube-battle-modal\" id=\"cubeBattleSection\" style=\"display: none;\">\n    <div class=\"modal-overlay\"></div>\n    <div class=\"modal-content\">\n        <div class=\"cube-battle-container\">\n            <div class=\"cube-battle-header\">\n                <h3>⚔️ Пиксель Рояль</h3>\n                <p>Top-Down баттл рояль! Последний выживший побеждает!</p>\n                <div class=\"cube-battle-stats\">\n                    <span id=\"cubeBattleAlive\" class=\"alive-count\">Выживших: 0</span>\n                    <span id=\"cubeBattleEliminated\" class=\"eliminated-count\">Уничтожено: 0</span>\n                </div>\n            </div>\n            \n            <div class=\"cube-battle-arena\" id=\"cubeBattleArena\">\n                <canvas id=\"cubeBattleCanvas\"></canvas>\n                <div class=\"battle-overlay\">\n                    <div class=\"battle-controls-hint\">\n                        <span class=\"key\">WASD</span> — камера | \n                        <span class=\"key\">Мышь</span> — перетаскивание | \n                        <span class=\"key\">Колёсико</span> — зум\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"cube-battle-controls\">\n                <button id=\"startCubeBattleBtn\" class=\"btn-primary btn-start-battle\">\n                    <i class=\"fas fa-play\"></i>\n                    <span>Начать Бой!</span>\n                </button>\n                <button id=\"closeCubeBattleBtn\" class=\"btn-secondary\">\n                    <i class=\"fas fa-times\"></i>\n                    <span>Закрыть</span>\n                </button>\n            </div>\n\n            <div class=\"cube-battle-winner\" id=\"cubeBattleWinner\" style=\"display: none;\">\n                <div class=\"winner-celebration\">\n                    <div class=\"confetti\"></div>\n                    <div class=\"confetti\"></div>\n                    <div class=\"confetti\"></div>\n                    <div class=\"confetti\"></div>\n                    <div class=\"confetti\"></div>\n                </div>\n                <div class=\"cube-winner-avatar\" id=\"cubeWinnerAvatar\">👑</div>\n                <div class=\"winner-info\">\n                    <div class=\"winner-name\" id=\"cubeWinnerName\">Победитель</div>\n                    <div class=\"winner-text\">Король арены! Последний выживший!</div>\n                    <div class=\"winner-stats\" id=\"cubeWinnerStats\">Уничтожено врагов: 0</div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js\"></script>\n<script src=\"js/pixbattle.js\"></script>\n\n    <script src=\"js/app3.js\"></script>\n<script src=\"js/winner-time.js\"></script>\n\n</body></html>",
