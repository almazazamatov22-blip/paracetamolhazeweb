    "html": "<html lang=\"ru\"><head>\n    <!-- Yandex.Metrika counter -->\n    <script async=\"\" src=\"https://mc.yandex.ru/metrika/tag.js?id=105293610\"></script><script type=\"text/javascript\">\n        (function(m,e,t,r,i,k,a){\n            m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};\n            m[i].l=1*new Date();\n            for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}\n            k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)\n        })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=105293610', 'ym');\n        ym(105293610, 'init', {ssr:true, clickmap:true, ecommerce:\"dataLayer\", accurateTrackBounce:true, trackLinks:true});\n    </script>\n    <noscript><div><img src=\"https://mc.yandex.ru/watch/105293610\" style=\"position:absolute; left:-9999px;\" alt=\"\" /></div></noscript>\n    <!-- /Yandex.Metrika counter -->\n    \n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Velgardi</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@100..900&amp;display=swap\" rel=\"stylesheet\">\n    <style>\n        body {\n            background-color: #111111;\n            color: white;\n            margin: 0;\n            padding: 0;\n            font-family: 'Inter', sans-serif;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 100vh;\n            overflow: hidden;\n            position: relative;\n        }\n\n        body::before {\n            content: '';\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background-image: \n                linear-gradient(to top right, rgba(0,0,0,0.4), transparent 75%), \n                linear-gradient(to bottom left, rgba(0,0,0,0.4), transparent 75%),\n                url('data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAYAAAAGCAYAAADgzD2BAAAALElEQVQIW2NkgALQzP+J/49B/Q9w7/8zMDDwPwAwA4iYAAAwAPgCgH5F5A4g+QWw/w8BABAAG+kBNdE2LwAAAABJRU5EVRKlggg==');\n            background-blend-mode: overlay, overlay, normal;\n            z-index: -1;\n            animation: subtleMove 60s linear infinite;\n        }\n\n        @keyframes subtleMove {\n            0%, 100% { transform: translate(0, 0); }\n            50% { transform: translate(1%, 1%); }\n        }\n\n        .content-container {\n            text-align: left;\n            line-height: 0.85;\n            padding: 20px;\n            padding-bottom: 100px;\n            transition: transform 0.3s ease-out;\n            transform-style: preserve-3d;\n            perspective: 1000px;\n            position: relative;\n            z-index: 1;\n            max-width: 100%;\n        }\n\n        .subtitle-top {\n            font-size: 2.5vh;\n            font-weight: 300;\n            letter-spacing: 0.3em;\n            opacity: 0.6;\n            margin-bottom: 3vh;\n            display: block;\n        }\n\n        .main-word {\n            display: flex;\n            align-items: flex-start;\n            font-size: 24vh;\n            font-weight: 900;\n            letter-spacing: -0.05em;\n            line-height: 0.9;\n            font-family: 'Inter', sans-serif;\n            margin-bottom: 4vh;\n            text-transform: uppercase;\n            text-shadow: 0 0 5px rgba(255, 255, 255, 0.2);\n        }\n\n        .word-container {\n            position: relative;\n            display: inline-block;\n        }\n\n        .word-base {\n            display: inline-block;\n        }\n\n        .di-highlight {\n            display: inline-block;\n            position: relative;\n            margin-left: 2px; \n        }\n\n        .di-letters {\n            display: inline-block;\n            position: relative;\n            z-index: 2;\n        }\n\n        .di-highlight::after {\n            content: '';\n            position: absolute;\n            top: -0.05em; \n            left: -0.1em;\n            right: -0.1em;\n            bottom: -0.05em;\n            background-color: #ff4500;\n            box-shadow: 0 0 15px rgba(255, 69, 0, 0.9);\n            z-index: 1;\n            animation: diPulse 2s ease-in-out infinite;\n        }\n\n        @keyframes diPulse {\n            0%, 100% {\n                background-color: #ff4500;\n                box-shadow: 0 0 15px rgba(255, 69, 0, 0.9);\n            }\n            50% {\n                background-color: #ff6a1a;\n                box-shadow: 0 0 25px rgba(255, 69, 0, 1);\n            }\n        }\n\n        .year-badge {\n            font-size: 5.5vh;\n            font-weight: 700;\n            background-color: #ff4500;\n            color: white;\n            padding: 1vh 2vh;\n            border-radius: 0;\n            margin-left: 2.5vh;\n            position: relative;\n            top: 3vh;\n            letter-spacing: 0.1em;\n            box-shadow: 0 0 8px rgba(255, 69, 0, 0.8);\n            animation: badgePulse 2s ease-in-out infinite;\n            display: inline-block;\n        }\n\n        @keyframes badgePulse {\n            0%, 100% {\n                background-color: #ff4500;\n                box-shadow: 0 0 8px rgba(255, 69, 0, 0.8);\n            }\n            50% {\n                background-color: #ff6a1a;\n                box-shadow: 0 0 18px rgba(255, 69, 0, 1);\n            }\n        }\n\n        .bottom-line {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            width: 100%;\n            max-width: 100%;\n            padding-top: 3vh;\n            border-top: 2px solid rgba(255, 255, 255, 0.8);\n            position: relative;\n        }\n\n        .bottom-line::before {\n            content: '//';\n            position: absolute;\n            left: 50%;\n            transform: translateX(-50%);\n            top: 0vh;\n            font-size: 3vh;\n            color: rgba(255, 255, 255, 0.8);\n            font-weight: 300;\n        }\n\n        .graphic-design, .ical-zalfa {\n            font-size: 3.5vh;\n            font-weight: 300;\n            opacity: 0.9;\n            letter-spacing: 0.3em;\n            text-transform: uppercase;\n        }\n\n        .projects-section {\n            margin-bottom: 4vh;\n            width: 100%;\n            max-width: 1400px;\n            padding: 0 20px;\n            box-sizing: border-box;\n        }\n        \n        .projects-title {\n            text-align: center;\n            font-size: 1.8vh;\n            font-weight: 400;\n            letter-spacing: 0.5em;\n            text-transform: uppercase;\n            opacity: 0.5;\n            margin-bottom: 30px;\n            color: rgba(255, 255, 255, 0.9);\n            position: relative;\n        }\n        \n        .projects-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n            gap: 25px;\n            justify-items: center;\n        }\n\n        .project-card {\n            width: 100%;\n            max-width: 280px;\n            background: rgba(30, 30, 30, 0.85);\n            border: 1px solid rgba(255, 255, 255, 0.12);\n            border-radius: 8px;\n            padding: 22px 20px;\n            text-align: center;\n            cursor: pointer;\n            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.45);\n            position: relative;\n            overflow: hidden;\n            transform-origin: center;\n        }\n\n        .project-card::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: -100%;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.08), transparent);\n            transition: left 0.7s;\n        }\n\n        .project-card:hover {\n            transform: translateY(-8px) scale(1.03);\n            background: rgba(40, 40, 40, 0.92);\n            box-shadow: 0 12px 35px rgba(0, 0, 0, 0.65);\n            border-color: rgba(255, 255, 255, 0.25);\n        }\n\n        .project-card:hover::before {\n            left: 100%;\n        }\n\n        .project-card:active {\n            transform: translateY(2px) scale(0.98);\n            transition: transform 0.15s ease;\n        }\n\n        .project-title {\n            font-family: 'Inter', sans-serif;\n            font-size: 2.4vh;\n            font-weight: 600;\n            letter-spacing: 0.12em;\n            text-transform: uppercase;\n            margin-bottom: 12px;\n            position: relative;\n            z-index: 2;\n            transition: color 0.3s ease;\n        }\n\n        .project-card:hover .project-title {\n            color: #ff4500;\n        }\n\n        .project-desc {\n            font-family: 'Inter', sans-serif;\n            font-size: 1.9vh;\n            font-weight: 300;\n            opacity: 0.85;\n            line-height: 1.5;\n            position: relative;\n            z-index: 2;\n            transition: opacity 0.3s ease;\n        }\n\n        .project-card:hover .project-desc {\n            opacity: 1;\n        }\n\n        .project-card::after {\n            content: '';\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            width: 100%;\n            height: 3px;\n            background: #ff4500;\n            transform: scaleX(0);\n            transform-origin: right;\n            transition: transform 0.4s ease;\n        }\n\n        .project-card:hover::after {\n            transform: scaleX(1);\n            transform-origin: left;\n        }\n\n        @media (max-width: 768px) {\n            .subtitle-top { font-size: 1.8vh; }\n            .main-word { font-size: 14vh; margin-bottom: 2vh; }\n            .year-badge { \n                font-size: 3vh; \n                padding: 0.5vh 1.5vh; \n                margin-left: 1.5vh; \n                top: 1vh; \n            }\n            .graphic-design, .ical-zalfa { font-size: 2vh; }\n            .bottom-line { \n                flex-direction: column; \n                align-items: flex-start; \n                padding-top: 2vh; \n            }\n            .ical-zalfa { margin-top: 1vh; }\n            .bottom-line::before { content: none; }\n            \n            .projects-section { margin-top: 4vh; }\n            .projects-grid { grid-template-columns: 1fr; gap: 20px; }\n            .project-title { font-size: 2.8vh; }\n            .project-desc { font-size: 2.3vh; }\n            .content-container { padding-bottom: 70px; }\n        }\n\n        @media (max-width: 480px) {\n            .project-title { font-size: 3.2vh; }\n            .project-desc { font-size: 2.6vh; }\n            .project-card { padding: 24px 15px; }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"content-container\">\n        <span class=\"subtitle-top\">TWITCH: VEiGARDi</span>\n\n        <div class=\"main-word\">\n            <span class=\"word-container\">\n                <span class=\"word-base\">VELGAR</span>\n                <span class=\"di-highlight\">\n                    <span class=\"di-letters\">DI</span>\n                </span>\n            </span>\n        </div>\n        \n        <div class=\"projects-section\">\n    <div class=\"projects-title\"> ОНЛАЙН ПРОЕКТЫ</div>\n    <div class=\"projects-grid\">\n        <a href=\"https://velgardi.ru/velroll\" class=\"project-card\" aria-label=\"Offline Project\" style=\"text-decoration: none; color: inherit;\">\n            <div class=\"project-title\">VelRoll</div>\n            <div class=\"project-desc\">Розыгрыши в чате твича</div>\n        </a>\n        <a href=\"https://twicheck.ru/\" class=\"project-card\" aria-label=\"Online Project\" style=\"text-decoration: none; color: inherit;\">\n            <div class=\"project-title\">TwiCheck</div>\n            <div class=\"project-desc\">Просмотр подписок пользователя на twitch</div>\n        </a>\n        <a href=\"https://velgardi.ru/quiz/game\" class=\"project-card\" aria-label=\"Online Project\" style=\"text-decoration: none; color: inherit;\">\n            <div class=\"project-title\">STREAM QUIZ</div>\n            <div class=\"project-desc\">Кто самый умный в чате?</div>\n        </a>\n        <a href=\"https://velcam.ru/\" class=\"project-card\" aria-label=\"Online Project\" style=\"text-decoration: none; color: inherit;\">\n            <div class=\"project-title\">VelCam</div>\n            <div class=\"project-desc\">Онлайн просмотр фильмов и таймингов</div>\n        </a>\n    </div>\n</div>\n        \n        <div class=\"bottom-line\">\n            <span class=\"graphic-design\">Offline</span>\n            <span class=\"ical-zalfa\">online</span>\n        </div>\n    </div>\n\n    <script>\n        let ticking = false;\n        \n        document.addEventListener('mousemove', (e) => {\n            if (!ticking) {\n                requestAnimationFrame(() => {\n                    const container = document.querySelector('.content-container');\n                    const centerX = window.innerWidth / 2;\n                    const centerY = window.innerHeight / 2;\n                    const offsetX = (e.clientX - centerX) / 80; \n                    const offsetY = (e.clientY - centerY) / 80;\n                    \n                    container.style.transform = `\n                        translateX(${offsetX}px) \n                        translateY(${offsetY}px) \n                        rotateX(${-offsetY / 8}deg) \n                        rotateY(${offsetX / 8}deg)\n                    `;\n                    ticking = false;\n                });\n                ticking = true;\n            }\n        });\n\n        document.addEventListener('mouseleave', () => {\n            const container = document.querySelector('.content-container');\n            container.style.transform = 'none';\n        });\n\n        document.querySelectorAll('.project-card').forEach(card => {\n            card.addEventListener('mousemove', (e) => {\n                const rect = card.getBoundingClientRect();\n                const x = e.clientX - rect.left;\n                const y = e.clientY - rect.top;\n                \n                const centerX = rect.width / 2;\n                const centerY = rect.height / 2;\n                \n                const rotateX = (y - centerY) / 20;\n                const rotateY = (centerX - x) / 20;\n                \n                card.style.transform = `\n                    perspective(1000px) \n                    rotateX(${rotateX}deg) \n                    rotateY(${rotateY}deg)\n                    scale(1.03)\n                `;\n            });\n            \n            card.addEventListener('mouseleave', () => {\n                card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale(1)';\n            });\n        });\n    </script>\n\n</body></html>",
